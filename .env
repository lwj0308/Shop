# ============================================
# Shop 商城项目 - Docker Compose 环境变量配置
# 说明：所有 Docker 服务端口和密码在此统一管理
# 注意：Windows 环境下部分端口被 Hyper-V 保留，
#       如遇端口冲突请参考 docs/local-dev-guide.md
# ============================================

# ==============================
# MySQL 配置
# ==============================
MYSQL_PORT=4306
MYSQL_ROOT_PASSWORD=root

# ==============================
# Redis 配置
# ==============================
REDIS_PORT=6379

# ==============================
# Nacos 配置
# 说明：gRPC 端口 = HTTP 端口 + 1000（Nacos 2.x 规则）
# 注意：Windows Hyper-V 会保留 9776-9975 端口范围，
#   导致默认的 8848(HTTP) + 9848(gRPC) 端口无法绑定。
#   解决方案：HTTP 端口改为 8976，gRPC 自动变为 9976（在排除范围之外）
#   微服务配置中的默认端口也需同步修改为 8976
# ==============================
NACOS_PORT=8976
NACOS_GRPC_PORT=9976

# ==============================
# RocketMQ 配置
# 注意：默认端口 9876 在 Windows Hyper-V 保留范围内（9876-9975），
#   改为 9977（在排除范围之外）
#   微服务配置中的默认端口也需同步修改为 9977
# ==============================
ROCKETMQ_NAMESRV_PORT=9977
ROCKETMQ_BROKER_PORT=10911

# ==============================
# MinIO 配置
# ==============================
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# ==============================
# Elasticsearch 配置
# ==============================
ES_HTTP_PORT=9201
ES_TRANSPORT_PORT=9300
